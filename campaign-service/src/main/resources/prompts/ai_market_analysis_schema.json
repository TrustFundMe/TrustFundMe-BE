                },
                "confidence": {
                    "type": "string"
                },
                "requiresAttention": {
                    "type": "boolean"
                },
                "redFlags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "spendingAnalysis": {
