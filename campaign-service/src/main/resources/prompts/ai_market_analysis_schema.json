{
    "type": "json_schema",
    "json_schema": {
        "name": "audit_result",
        "schema": {
            "type": "object",
            "properties": {
                "summary": {
                    "type": "string"
                },
                "recommendation": {
                    "type": "string"
                },
                "riskScore": {
                    "type": "number"
                },
                "riskLevel": {
                    "type": "string"
                },
                "items": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "itemName": {
                                "type": "string"
                            },
                            "marketPrice": {
                                "type": "number"
                            },
                            "marketPriceMin": {
                                "type": "number"
                            },
                            "marketPriceMax": {
                                "type": "number"
                            },
                            "evidenceUrls": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "default": []
                            }
                        },
                        "required": [
                            "itemName",
                            "marketPrice",
                            "marketPriceMin",
                            "marketPriceMax",
                            "evidenceUrls"
                        ]
                    }
                }
            },
            "required": [
                "summary",
                "recommendation",
                "riskScore",
                "riskLevel",
                "items"
            ]
        }
    }
}